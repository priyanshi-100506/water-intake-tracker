# AI Hydration Intelligence Platform - Environment Variables

# Database
DATABASE_NAME=water_tracker.db

# Ollama Configuration
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.3

# API Configuration
API_HOST=127.0.0.1
API_PORT=8000

# Logging
LOG_LEVEL=INFO

# Features (set to True/False to enable/disable)
ENABLE_USER_PROFILES=True
ENABLE_AI_ANALYSIS=True
ENABLE_WEEKLY_REPORTS=True
